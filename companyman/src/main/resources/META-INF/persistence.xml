<?xml version="1.0" encoding="UTF-8"?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence
             https://jakarta.ee/xml/ns/persistence/persistence_3_1.xsd"
             version="3.1">

    <persistence-unit name="CompanyManPU" transaction-type="RESOURCE_LOCAL">
        <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>

        <class>br.com.rsdata.model.RamoAtividade</class>
        <class>br.com.rsdata.model.Empresa</class>

        <exclude-unlisted-classes>true</exclude-unlisted-classes>

        <properties>
            <!-- Valores padrão; sobrescritos em tempo de execução por JPAUtil usando
                 variáveis de ambiente. Propriedades definidas em ambos os "dialetos"
                 (jakarta.persistence.jdbc.* e hibernate.connection.*) porque o
                 HikariCPConnectionProvider só lê o segundo grupo, enquanto o
                 provider padrão do Hibernate (DriverManager) aceita ambos. -->
            <property name="jakarta.persistence.jdbc.driver" value="org.postgresql.Driver"/>
            <property name="jakarta.persistence.jdbc.url" value="jdbc:postgresql://localhost:5432/empresa_db"/>
            <property name="jakarta.persistence.jdbc.user" value="empresa_user"/>
            <property name="jakarta.persistence.jdbc.password" value="empresa_pass"/>

            <property name="hibernate.connection.driver_class" value="org.postgresql.Driver"/>
            <property name="hibernate.connection.url" value="jdbc:postgresql://localhost:5432/empresa_db"/>
            <property name="hibernate.connection.username" value="empresa_user"/>
            <property name="hibernate.connection.password" value="empresa_pass"/>

            <property name="hibernate.dialect" value="org.hibernate.dialect.PostgreSQLDialect"/>
            <property name="hibernate.hbm2ddl.auto" value="update"/>
            <property name="hibernate.show_sql" value="true"/>
            <property name="hibernate.format_sql" value="true"/>
            <property name="hibernate.physical_naming_strategy"
                       value="org.hibernate.boot.model.naming.CamelCaseToUnderscoresNamingStrategy"/>

            <!-- Pool de conexões HikariCP (mais robusto que o DriverManager padrão:
                 timeouts configuráveis e mensagens de erro mais claras). -->
            <property name="hibernate.connection.provider_class"
                       value="org.hibernate.hikaricp.internal.HikariCPConnectionProvider"/>
            <property name="hibernate.hikari.poolName" value="EmpresaCRUDPool"/>
            <property name="hibernate.hikari.minimumIdle" value="2"/>
            <property name="hibernate.hikari.maximumPoolSize" value="10"/>
            <property name="hibernate.hikari.idleTimeout" value="30000"/>
            <property name="hibernate.hikari.connectionTimeout" value="20000"/>
        </properties>
    </persistence-unit>
</persistence>